# ─────────────────────────────────────────────
# I-Architect v2.3 — Environment Variables
# ─────────────────────────────────────────────

# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,orchestrator

# Database
POSTGRES_DB=iarchitect
POSTGRES_USER=iarchitect
POSTGRES_PASSWORD=iarchitect
DATABASE_URL=postgres://iarchitect:iarchitect@postgres:5432/iarchitect

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# External Services
CHROMADB_URL=http://i-architect-chromadb:8000
PLANTUML_URL=http://plantuml-server:8080

# Media
MEDIA_ROOT=/app/media

# ARLO Defaults
ARLO_BATCH_SIZE=10
ARLO_ILP_TIMEOUT_SECONDS=120

# Project Limits
PROJECT_DISK_QUOTA_MB=500
PROJECT_MAX_VERSIONS=5
